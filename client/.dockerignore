# =============================================================================
# client/.dockerignore — applied when building with context `./client`
# Goal: send only the source needed for `pnpm install && pnpm build`.
# node_modules and dist are regenerated inside the image; everything user-
# generated (logs, coverage, cypress recordings) stays out.
# =============================================================================

# Version control
.git
.github
.gitignore
.gitattributes

# Editor / OS noise
.idea
.vscode
.vs
*.swp
*.swo
.DS_Store
Thumbs.db
.editorconfig

# Env files — Vite reads these at build time, but we pass VITE_* via build
# args, so the files themselves should never enter the image.
.env
.env.*
!.env.example

# Dependencies — regenerated by `pnpm install` in the Dockerfile
node_modules

# Build outputs — regenerated by `pnpm build` in the Dockerfile
dist
build
.cache
.next
.parcel-cache
.vite
stats.html

# Test / coverage artefacts (test source IS included so vitest works in dev)
coverage
.nyc_output
cypress/screenshots
cypress/videos
cypress/downloads

# Logs
*.log
npm-debug.log
pnpm-debug.log
yarn-error.log

# Docs / meta
README.md
*.md

# Compose files live at repo root — never copy them into the client context
docker-compose*.yml
docker-compose*.yaml
