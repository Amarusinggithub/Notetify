# =============================================================================
# api/.dockerignore — applied when building with context `./api`
# Goal: send only what Composer/PHP needs into the daemon. Everything else is
# either regenerated inside the image (vendor) or volume-mounted at runtime.
# =============================================================================

# Version control
.git
.github
.gitignore
.gitattributes

# Editor / OS noise
.idea
.vscode
.vs
*.swp
*.swo
.DS_Store
Thumbs.db
.editorconfig

# Env files — never bake into the image. Keep the example as a reference.
.env
.env.*
!.env.example

# Dependencies — regenerated by `composer install` in the Dockerfile
vendor
node_modules

# Laravel runtime artefacts (must be writable, not baked in)
storage/logs/*
!storage/logs/.gitignore
storage/framework/cache/data/*
!storage/framework/cache/data/.gitignore
storage/framework/sessions/*
!storage/framework/sessions/.gitignore
storage/framework/views/*
!storage/framework/views/.gitignore
storage/app/public/*
!storage/app/public/.gitignore
bootstrap/cache/*.php
public/storage

# Test / coverage artefacts (tests source IS included; only outputs excluded)
.phpunit.result.cache
.phpunit.cache
coverage
.cache

# Docs and meta
README.md
CHANGELOG.md
*.md

# Compose files live at repo root — never copy them into the api context
docker-compose*.yml
docker-compose*.yaml

# Logs
*.log
npm-debug.log
pnpm-debug.log
