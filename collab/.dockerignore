# =============================================================================
# collab/.dockerignore — applied when building with context `./collab`
# Goal: send only the source needed for `pnpm install && pnpm build`.
# node_modules and dist are regenerated inside the image.
# =============================================================================

# Version control
.git
.github
.gitignore
.gitattributes

# Editor / OS noise
.idea
.vscode
.vs
*.swp
*.swo
.DS_Store
Thumbs.db
.editorconfig

# Env files — passed via Docker Compose environment, never baked into image
.env
.env.*
!.env.example

# Dependencies — regenerated by `pnpm install` in the Dockerfile
node_modules

# Build outputs — regenerated by `pnpm build` in the Dockerfile
dist

# Logs
*.log
npm-debug.log
pnpm-debug.log
yarn-error.log

# Docs / meta
README.md
*.md

# Compose files live at repo root
docker-compose*.yml
docker-compose*.yaml
